---
const { product } = Astro.props;
const rows = product.files || [];
const legacy = product.files && !Array.isArray(product.files) ? product.files : {};
const legacyRows = [
  ...(legacy.pdfs || []),
  ...(legacy.dwgs || []),
  ...(legacy.models3d || []),
  ...(legacy.other || []),
].map((item) => typeof item === "string" ? { url: item, label: "Dosya" } : item);
const files = Array.isArray(rows) ? rows : legacyRows;
---
<section class="card files-card">
  <h2 class="section-title">Teknik Dosyalar</h2>
  {files.length ? (
    <ul>
      {files.map((file) => (
        <li><a href={file.url || file.file_url || "#"} target="_blank" rel="noopener noreferrer">{file.label || file.name || file.file_type || "Dosya"}</a></li>
      ))}
    </ul>
  ) : (
    <p>PDF, CAD veya BIM dosyası henüz eklenmedi.</p>
  )}
</section>
<style>
  .files-card { padding: 22px; }
  ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
  a { display: flex; justify-content: space-between; min-height: 44px; align-items: center; border: 1px solid rgba(0,0,0,.08); border-radius: 10px; padding: 0 14px; font-size: 14px; }
  a::after { content: "↓"; color: #6e6e73; }
  p { margin: 0; color: #6e6e73; font-size: 14px; }
</style>

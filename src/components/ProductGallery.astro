---
import { galleryForProduct } from "../lib/catalog.js";
const { product } = Astro.props;
const images = galleryForProduct(product, product.images || []);
---
<section class="gallery" aria-label="Ürün galerisi">
  {images.length ? (
    <>
      <figure class="main"><img src={images[0]} alt={product.name} width="1100" height="820" /></figure>
      {images.length > 1 && <div class="thumbs">{images.slice(1, 5).map((src) => <img src={src} alt="" loading="lazy" width="180" height="135" />)}</div>}
    </>
  ) : (
    <div class="empty">Bu ürün için görsel henüz eklenmedi.</div>
  )}
</section>
<style>
  .gallery { display: grid; gap: 12px; }
  .main { margin: 0; aspect-ratio: 4 / 3; border-radius: 16px; overflow: hidden; background: #f5f5f7; }
  .main img { width: 100%; height: 100%; object-fit: contain; }
  .thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
  .thumbs img { aspect-ratio: 4 / 3; width: 100%; height: 100%; object-fit: cover; border-radius: 10px; background: #f5f5f7; }
</style>

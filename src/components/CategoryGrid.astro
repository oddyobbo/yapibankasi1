---
import { categoryPath } from "../lib/slugs.js";
const { categories = [] } = Astro.props;
---
{categories.length ? (
  <div class="category-grid">
    {categories.map((category) => (
      <a class="card category-card" href={categoryPath(category)}>
        <span>{category.name}</span>
        {category.description ? <p>{category.description}</p> : null}
        <small>Ürünleri gör</small>
      </a>
    ))}
  </div>
) : (
  <p class="empty">Kategori henüz eklenmedi.</p>
)}
<style>
  .category-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 14px; }
  .category-card {
    min-height: 148px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 18px;
    background:
      linear-gradient(140deg, rgba(255,255,255,.86), rgba(255,255,255,1)),
      radial-gradient(circle at 0 0, rgba(0,0,0,.08), transparent 38%);
    transition: border-color .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .category-card:hover {
    border-color: rgba(0,0,0,.24);
    transform: translateY(-2px);
    box-shadow: 0 18px 42px rgba(0,0,0,.07);
  }
  span { font-size: 19px; line-height: 1.2; font-weight: 500; letter-spacing: 0; }
  p {
    margin: 8px 0 0;
    color: #6e6e73;
    font-size: 13px;
    line-height: 1.45;
  }
  small {
    margin-top: 16px;
    color: #111;
    font-size: 12px;
  }
</style>

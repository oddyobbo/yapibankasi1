---
import { brandPath, slugify } from "../lib/slugs.js";
import { imageForProduct } from "../lib/catalog.js";
import { productPath } from "../lib/slugs.js";
const { product, brand, categoryLabel = "", relatedProducts = [] } = Astro.props;
const name = brand?.name || product?.brand_name || "Marka belirtilmedi";
const href = brand ? brandPath(brand) : `/brands/${slugify(name)}`;
const roles = Array.isArray(product?.company_roles) ? product.company_roles : [];
const chips = [
  categoryLabel || product?.category,
  product?.material,
  product?.usage_area,
].filter(Boolean).slice(0, 4);
const variants = (product?.variants || []).slice(0, 4);
const params = new URLSearchParams({
  konu: "urun",
  talep: "teklif",
  urun: product?.name || "",
  marka: product?.brand_name || "",
  urunId: product?.id || "",
});
---
<aside class="product-detail-brand-card">
  <div class="product-detail-brand-topline">
    <div class="product-detail-brand-identity">
      <div class="product-detail-brand-logo-slot">
        {(brand?.logo_url || product?.brand_logo) ? <img src={brand?.logo_url || product?.brand_logo} alt={name} width="160" height="90" /> : <span>{name.charAt(0)}</span>}
      </div>
      <div>
        <p>Marka</p>
        <h2>{name}</h2>
      </div>
    </div>
    <a class="save-btn" href="/mimar-giris.html">Kaydet</a>
  </div>

  <h1>{product.name}</h1>
  <p class="lede">{product.summary || product.description || brand?.description || "Bu ürün için kısa açıklama henüz eklenmedi."}</p>

  {variants.length > 0 && (
    <div class="variants" aria-label="Varyantlar">
      <p>Varyantlar</p>
      <div>
        {variants.map((variant) => <span>{variant.name || variant.finish || variant.size || "Varyant"}</span>)}
      </div>
    </div>
  )}

  {chips.length > 0 && <div class="chip-row">{chips.map((chip) => <span>{chip}</span>)}</div>}
  {roles.length > 0 && <div class="role-row">{roles.map((role) => <span>{role}</span>)}</div>}

  <div class="actions">
    <a class="primary" href={`/iletisim-v2.html?${params.toString()}`}>Fiyat teklifi al</a>
    <a href="/mimar-paneli.html?tab=moodboards">Moodboard'a kaydet</a>
    <a href="/iletisim-v2.html">Markayla iletişime geç</a>
  </div>

  <div class="more-block">
    <div class="more-head">
      <a href={href}>Markanın Diğer Ürünlerini Gör</a>
      <span aria-hidden="true">›</span>
    </div>
    {relatedProducts.length ? (
      <div class="preview-strip">
        {relatedProducts.slice(0, 8).map((item) => (
          <a href={productPath(item)}>
            <span class="preview-thumb">{imageForProduct(item) ? <img src={imageForProduct(item)} alt="" loading="lazy" width="120" height="90" /> : null}</span>
            <span class="preview-name">{item.name}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="preview-empty">Markanın diğer ürünleri eklendikçe burada görünecek.</p>
    )}
  </div>
</aside>
<style>
  .product-detail-brand-card {
    padding: 28px;
    border: 1px solid rgba(255,255,255,.42);
    border-radius: 28px;
    background: rgba(245,245,247,.86);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: 0 18px 48px rgba(0,0,0,.12);
  }
  .product-detail-brand-topline {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }
  .product-detail-brand-identity {
    display: flex;
    align-items: center;
    gap: 13px;
    min-width: 0;
  }
  .product-detail-brand-logo-slot {
    width: 118px;
    height: 58px;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 12px;
    background: #fff;
  }
  .product-detail-brand-logo-slot img {
    max-width: 88%;
    max-height: 72%;
    object-fit: contain;
  }
  .product-detail-brand-logo-slot span {
    color: #111;
    font-size: 26px;
    font-weight: 600;
  }
  p {
    margin: 0;
  }
  .product-detail-brand-identity p {
    color: #8e8e93;
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  h2 {
    margin: 4px 0 0;
    color: #111;
    font-size: 15px;
    line-height: 1.15;
    font-weight: 500;
  }
  .save-btn {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0,0,0,.1);
    border-radius: 12px;
    background: rgba(255,255,255,.78);
    padding: 0 15px;
    color: #111;
    font-size: 13px;
    font-weight: 400;
  }
  h1 {
    margin: 28px 0 0;
    color: #0b0b0c;
    font-size: clamp(26px, 2.15vw, 34px);
    line-height: 1.14;
    letter-spacing: 0;
    font-weight: 600;
  }
  .lede {
    margin: 12px 0 0;
    color: #515154;
    font-size: 15px;
    line-height: 1.58;
  }
  .variants {
    margin-top: 22px;
  }
  .variants > p {
    color: #6e6e73;
    font-size: 13px;
  }
  .variants > div,
  .chip-row,
  .role-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }
  .variants span,
  .chip-row span,
  .role-row span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 999px;
    background: rgba(255,255,255,.72);
    padding: 0 11px;
    color: #333;
    font-size: 12px;
    font-weight: 400;
  }
  .actions {
    display: grid;
    gap: 10px;
    margin-top: 24px;
  }
  .actions a {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0,0,0,.14);
    border-radius: 14px;
    background: rgba(255,255,255,.62);
    color: #0b0b0c;
    font-size: 14px;
    font-weight: 400;
  }
  .actions a.primary {
    border-color: #0b0b0c;
    background: #0b0b0c;
    color: #fff;
  }
  .more-block {
    margin-top: 24px;
    border-top: 1px solid rgba(0,0,0,.08);
    padding-top: 18px;
  }
  .more-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .more-head a {
    color: #0b0b0c;
    font-size: 14px;
    font-weight: 400;
  }
  .more-head span {
    color: #8e8e93;
    font-size: 20px;
  }
  .preview-strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    margin-top: 14px;
    padding-bottom: 4px;
  }
  .preview-strip a {
    width: 96px;
    flex: 0 0 auto;
    color: #111;
  }
  .preview-thumb {
    display: grid;
    aspect-ratio: 4 / 3;
    place-items: center;
    overflow: hidden;
    border-radius: 12px;
    background: rgba(255,255,255,.78);
  }
  .preview-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .preview-name {
    display: -webkit-box;
    overflow: hidden;
    margin-top: 7px;
    color: #424245;
    font-size: 11px;
    line-height: 1.25;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .preview-empty {
    margin-top: 12px;
    color: #6e6e73;
    font-size: 12px;
    line-height: 1.45;
  }
</style>

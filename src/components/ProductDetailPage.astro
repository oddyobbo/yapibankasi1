---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import ProductGallery from "./ProductGallery.astro";
import TechnicalSpecs from "./TechnicalSpecs.astro";
import DownloadFiles from "./DownloadFiles.astro";
import RelatedProducts from "./RelatedProducts.astro";
import RelatedProjects from "./RelatedProjects.astro";
import RequestQuoteCTA from "./RequestQuoteCTA.astro";
import BrandSummaryCard from "./BrandSummaryCard.astro";
import ContactBrandModal from "./ContactBrandModal.astro";
import { imageForProduct } from "../lib/catalog.js";
import { productPath } from "../lib/slugs.js";

export interface Props {
  product: any;
}

const { product } = Astro.props;
const brand = product.brand || null;
const categoryLabel = [
  product.categoryRecord?.name || "",
  product.subcategoryRecord?.name || "",
].filter(Boolean).join(" / ") || product.category || "Kategori belirtilmedi";
const description = product.description || product.summary || "";
const usageValues = [
  product.usage_area,
  product.indoor_outdoor,
  product.acoustic_rating,
  product.color_family,
].filter(Boolean);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  image: imageForProduct(product) ? [imageForProduct(product)] : undefined,
  description: product.summary || product.description,
  brand: (brand?.name || product.brand_name) ? { "@type": "Brand", name: brand?.name || product.brand_name } : undefined,
  sku: product.sku || undefined,
  category: categoryLabel || undefined,
};
---
<BaseLayout
  title={`${product.name} | ${brand?.name || product.brand_name || "Archilink"} | Archilink`}
  description={product.summary || product.description || `${product.name} teknik bilgileri, dosyaları ve marka detayları.`}
  canonical={productPath(product)}
  image={imageForProduct(product)}
  type="product"
  jsonLd={jsonLd}
>
  <Header />
  <main class="product-detail-page">
    <div class="product-detail-shell page-shell">
      <div class="product-detail-layout">
        <div class="product-detail-main">
          <article class="product-detail-section product-detail-hero-panel">
            <ProductGallery product={product} />
          </article>

          <div class="product-detail-heading">
            <p class="product-detail-hero-kicker ag-pill-meta">{categoryLabel}</p>
          </div>

          <section class="product-detail-section ag-panel-section product-detail-description-block">
            <h2 class="ag-panel-title">Ürün Açıklaması</h2>
            <p class="ag-pill-body">{description || "Bu ürün için açıklama henüz eklenmedi."}</p>
          </section>

          <div class="product-detail-section">
            <TechnicalSpecs product={product} />
          </div>

          <section class="product-detail-section ag-panel-section variants-section">
            <div class="section-title-row">
              <h2 class="ag-panel-title">Varyantlar</h2>
              {product.variants?.length ? <span class="ag-pill-meta">{product.variants.length}</span> : null}
            </div>
            {product.variants?.length ? (
              <div class="variant-grid">
                {product.variants.map((variant) => (
                  <article class="variant">
                    <strong>{variant.name || "Varyant"}</strong>
                    <span class="ag-pill-body">{[variant.finish, variant.size, variant.material].filter(Boolean).join(" · ") || "Detay bilgisi eklenmedi."}</span>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty-line ag-pill-body">Bu ürün için varyant bilgisi henüz eklenmedi.</p>
            )}
          </section>

          <section class="info-grid">
            <DownloadFiles product={product} />
            <article class="product-detail-section ag-panel-section usage-card">
              <h2 class="ag-panel-title">Kullanım Alanları</h2>
              {usageValues.length ? (
                <ul>{usageValues.map((item) => <li class="ag-pill-body">{item}</li>)}</ul>
              ) : (
                <p class="empty-line ag-pill-body">Kullanım alanı bilgisi henüz eklenmedi.</p>
              )}
            </article>
          </section>

          <section class="info-grid">
            <RelatedProjects projects={product.relatedProjects || []} />
            <RequestQuoteCTA product={product} />
          </section>
        </div>

        <aside class="product-detail-aside" aria-label="Marka ve ürün özeti">
          <BrandSummaryCard product={product} brand={brand} categoryLabel={categoryLabel} relatedProducts={product.relatedProducts || []} />
        </aside>
      </div>
    </div>

    <RelatedProducts products={product.relatedProducts || []} />
  </main>
  <ContactBrandModal product={product} brand={brand} />
  <Footer />
</BaseLayout>
<style>
  .product-detail-page {
    background: var(--ag-canvas);
    color: var(--ag-text);
  }

  .product-detail-shell.page-shell {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding: 20px 40px 3.5rem;
    box-sizing: border-box;
  }

  .product-detail-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 400px);
    gap: clamp(20px, 3vw, 40px);
    align-items: start;
  }

  .product-detail-main {
    display: grid;
    gap: 16px;
    min-width: 0;
  }

  .product-detail-aside {
    position: sticky;
    top: calc(var(--ag-header-h) + 0.75rem);
    align-self: start;
    min-width: 0;
    max-height: calc(100vh - var(--ag-header-h) - 1.25rem);
    overflow: auto;
  }

  .product-detail-section {
    min-width: 0;
  }

  .product-detail-section.product-detail-hero-panel {
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .product-detail-heading {
    margin: 0;
  }

  .product-detail-hero-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    color: #6e6e73;
  }

  .product-detail-section.ag-panel-section .ag-panel-title {
    margin: 0 0 0.875rem;
  }

  .product-detail-description-block p,
  .empty-line {
    margin: 0;
    max-width: 72ch;
    line-height: 1.55;
    color: var(--ag-subtle);
  }

  .section-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .section-title-row h2 {
    margin: 0;
  }

  .section-title-row span {
    min-width: 32px;
    min-height: 26px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: #fafafa;
    padding: 0 8px;
    color: #424245;
    font-weight: 500;
  }

  .variant-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 12px;
  }

  .variant {
    display: grid;
    gap: 8px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 14px 16px;
    background: #fafafa;
  }

  .variant strong {
    font-size: 14px;
    font-weight: 600;
  }

  .variant span {
    color: #6e6e73;
    line-height: 1.45;
  }

  .info-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 1fr);
    gap: 18px;
    min-width: 0;
  }

  .info-grid > :global(section),
  .info-grid > :global(div),
  .info-grid > article {
    min-width: 0;
  }

  .usage-card ul {
    list-style: none;
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  .usage-card li {
    min-height: 40px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    color: #424245;
  }

  @media (max-width: 1024px) {
    .product-detail-shell.page-shell {
      padding-left: 24px;
      padding-right: 24px;
    }
  }

  @media (max-width: 1099px) {
    .product-detail-layout {
      grid-template-columns: 1fr;
    }

    .product-detail-aside {
      position: static;
      max-height: none;
      overflow: visible;
      order: -1;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .product-detail-shell.page-shell {
      padding-left: 16px;
      padding-right: 16px;
      padding-top: 16px;
    }
  }
</style>

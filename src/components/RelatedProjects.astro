---
import ProjectCard from "./ProjectCard.astro";
const { projects = [] } = Astro.props;
---
<section class="page-band">
  <div class="container">
    <h2 class="section-title">İlgili Projeler</h2>
    {projects.length ? <div class="grid cards">{projects.map((project) => <ProjectCard project={project} />)}</div> : <p class="empty">İlgili proje henüz yok.</p>}
  </div>
</section>

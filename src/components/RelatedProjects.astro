---
import ProjectCard from "./ProjectCard.astro";
const { projects = [] } = Astro.props;
---
<section class="ag-panel-section related-projects">
  <h2 class="ag-panel-title">İlgili Projeler</h2>
  {projects.length ? <div class="project-list">{projects.slice(0, 4).map((project) => <ProjectCard project={project} />)}</div> : <p>İlgili proje henüz yok.</p>}
</section>
<style>
  .related-projects {
    padding: 0;
    border: 0;
    box-shadow: none;
  }
  .related-projects .ag-panel-title {
    margin: 0 0 1rem;
  }
  .project-list { display: grid; gap: 12px; }
  p { margin: 0; color: #6e6e73; font-size: 14px; line-height: 1.5; }
</style>

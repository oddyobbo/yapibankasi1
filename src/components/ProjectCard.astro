---
import { projectPath } from "../lib/slugs.js";
const { project } = Astro.props;
const image = project.heroImage || project.image || project.images?.[0]?.url || "";
const meta = [project.location || [project.city, project.country].filter(Boolean).join(", "), project.architect || project.office_name || project.brand_name]
  .filter(Boolean)
  .join(" · ");
const materials = Array.isArray(project.materials) ? project.materials.filter(Boolean).slice(0, 3) : [];
const productCount = project.product_count || project.products?.length || 0;
---
<a class="project-card card" href={projectPath(project)}>
  <div class="media">
    {image ? <img src={image} alt={project.title} loading="lazy" width="720" height="460" /> : <span>Görsel yok</span>}
  </div>
  <div class="copy">
    <h2>{project.title}</h2>
    {meta ? <p class="meta">{meta}</p> : null}
    <p>{project.description || "Proje açıklaması henüz eklenmedi."}</p>
    <div class="project-tags">
      {materials.map((material) => <span>{material}</span>)}
      {productCount ? <span>{productCount} ürün</span> : null}
    </div>
  </div>
</a>
<style>
  .project-card {
    display: block;
    border-radius: 20px;
    transition: border-color .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .project-card:hover {
    border-color: rgba(0,0,0,.22);
    transform: translateY(-2px);
    box-shadow: 0 18px 45px rgba(0,0,0,.08);
  }
  .media { aspect-ratio: 16 / 10; display: grid; place-items: center; background: #f5f5f7; color: #8e8e93; font-size: 13px; overflow: hidden; }
  img { width: 100%; height: 100%; object-fit: cover; }
  .copy { padding: 18px; }
  h2 { margin: 0; font-size: 19px; line-height: 1.22; font-weight: 500; letter-spacing: 0; }
  .meta { margin: 8px 0 0; color: #6e6e73; font-size: 12px; }
  .copy > p:last-child { margin: 10px 0 0; color: #6e6e73; font-size: 13px; line-height: 1.45; }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 15px;
  }
  .project-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    border: 1px solid rgba(0,0,0,.09);
    border-radius: 999px;
    padding: 0 10px;
    background: #fafafa;
    color: #4a4a4f;
    font-size: 12px;
    font-weight: 400;
  }
</style>

---
import { projectPath } from "../lib/slugs.js";
const { project } = Astro.props;
---
<a class="project-card card" href={projectPath(project)}>
  <div class="media">
    {project.image ? <img src={project.image} alt={project.title} loading="lazy" width="720" height="460" /> : <span>Görsel yok</span>}
  </div>
  <div class="copy">
    <h2>{project.title}</h2>
    <p class="meta">{[project.location, project.architect || project.office_name || project.brand_name].filter(Boolean).join(" · ")}</p>
    <p>{project.description || "Proje açıklaması henüz eklenmedi."}</p>
  </div>
</a>
<style>
  .project-card { display: block; }
  .media { aspect-ratio: 16 / 10; display: grid; place-items: center; background: #f5f5f7; color: #8e8e93; font-size: 13px; }
  img { width: 100%; height: 100%; object-fit: cover; }
  .copy { padding: 16px; }
  h2 { margin: 0; font-size: 18px; line-height: 1.25; font-weight: 600; }
  .meta { margin: 8px 0 0; color: #6e6e73; font-size: 12px; }
  .copy > p:last-child { margin: 10px 0 0; color: #6e6e73; font-size: 13px; line-height: 1.45; }
</style>

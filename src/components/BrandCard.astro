---
import { brandPath } from "../lib/slugs.js";
const { brand } = Astro.props;
const roles = Array.isArray(brand.company_roles) ? brand.company_roles : [];
const location = [brand.city, brand.country].filter(Boolean).join(", ");
---
<a class="brand-card card" href={brandPath(brand)}>
  <div class="brand-card-top">
    <div class="logo">
      {brand.logo_url ? <img src={brand.logo_url} alt={brand.name} loading="lazy" width="180" height="90" /> : <span>{brand.name?.charAt(0) || "M"}</span>}
    </div>
    <span class="arrow" aria-hidden="true">→</span>
  </div>
  <div class="copy">
    <h2>{brand.name}</h2>
    <p>{brand.description || location || "Marka açıklaması henüz eklenmedi."}</p>
  </div>
  {(roles.length || location) && (
    <div class="meta">
      {roles.slice(0, 2).map((role) => <span>{role}</span>)}
      {location && <span>{location}</span>}
    </div>
  )}
</a>
<style>
  .brand-card {
    min-height: 220px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    border-radius: 22px;
    padding: 20px;
    background: #fff;
    transition: border-color .22s ease, box-shadow .22s ease, transform .22s ease;
  }
  .brand-card:hover {
    border-color: rgba(0,0,0,.22);
    box-shadow: 0 18px 42px rgba(0,0,0,.06);
    transform: translateY(-2px);
  }
  .brand-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }
  .logo {
    width: 132px;
    height: 76px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 14px;
    background: #fff;
  }
  .logo span { font-size: 30px; font-weight: 600; }
  img { max-width: 90%; max-height: 80%; object-fit: contain; }
  .arrow {
    display: inline-grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid rgba(0,0,0,.1);
    border-radius: 999px;
    color: #1d1d1f;
    font-size: 15px;
  }
  .copy {
    min-height: 84px;
  }
  h2 {
    margin: 0;
    color: #1d1d1f;
    font-size: 20px;
    line-height: 1.18;
    font-weight: 600;
    letter-spacing: 0;
  }
  p {
    display: -webkit-box;
    overflow: hidden;
    margin: 10px 0 0;
    color: #6e6e73;
    font-size: 13px;
    line-height: 1.5;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: auto;
  }
  .meta span {
    display: inline-flex;
    min-height: 26px;
    align-items: center;
    border-radius: 999px;
    background: #f5f5f7;
    padding: 0 10px;
    color: #424245;
    font-size: 11px;
    font-weight: 400;
  }
</style>

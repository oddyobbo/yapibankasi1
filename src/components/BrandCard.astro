---
import { brandPath } from "../lib/slugs.js";
const { brand } = Astro.props;
---
<a class="brand-card card" href={brandPath(brand)}>
  <div class="logo">
    {brand.logo_url ? <img src={brand.logo_url} alt={brand.name} loading="lazy" width="180" height="90" /> : <span>{brand.name?.charAt(0) || "M"}</span>}
  </div>
  <div>
    <h2>{brand.name}</h2>
    <p>{brand.description || [brand.city, brand.country].filter(Boolean).join(", ") || "Marka açıklaması henüz eklenmedi."}</p>
  </div>
</a>
<style>
  .brand-card { min-height: 190px; display: grid; gap: 18px; padding: 18px; }
  .logo { width: 120px; height: 70px; display: grid; place-items: center; border: 1px solid rgba(0,0,0,.08); border-radius: 10px; background: #fff; }
  .logo span { font-size: 28px; font-weight: 600; }
  img { max-width: 90%; max-height: 80%; object-fit: contain; }
  h2 { margin: 0; font-size: 19px; line-height: 1.2; font-weight: 600; }
  p { margin: 10px 0 0; color: #6e6e73; font-size: 13px; line-height: 1.5; }
</style>

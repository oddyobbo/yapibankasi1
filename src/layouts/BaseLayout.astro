---
import SEO from "../components/SEO.astro";

const {
  title,
  description,
  canonical,
  image,
  type,
  jsonLd,
} = Astro.props;
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} canonical={canonical} image={image} type={type} jsonLd={jsonLd} />
    <style is:global>
      :root {
        color-scheme: light;
        --ink: #111111;
        --muted: #6e6e73;
        --line: rgba(0, 0, 0, 0.1);
        --soft: #f5f5f7;
        --paper: #ffffff;
        --radius-lg: 22px;
        --radius-md: 16px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: #fafafa;
        color: var(--ink);
        font-family: "SF Pro Text", "SF Pro Display", "SF Pro", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        font-weight: 400;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }
      .container { width: min(1280px, calc(100% - 48px)); margin: 0 auto; }
      .page-band { padding: 44px 0; }
      .eyebrow { color: var(--muted); font-size: 13px; line-height: 1.5; }
      .page-title { margin: 0; font-size: clamp(30px, 5vw, 52px); line-height: 1.04; letter-spacing: 0; font-weight: 600; }
      .section-title { margin: 0 0 18px; font-size: 22px; line-height: 1.15; font-weight: 600; }
      .lead { max-width: 720px; color: var(--muted); font-size: 16px; line-height: 1.65; }
      .grid { display: grid; gap: 18px; }
      .grid.cards { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }
      .card {
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: var(--paper);
        overflow: hidden;
      }
      .empty {
        border: 1px dashed rgba(0,0,0,.18);
        border-radius: var(--radius-md);
        padding: 28px;
        color: var(--muted);
        background: #fff;
      }
      .button {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 999px;
        border: 1px solid #111;
        padding: 0 18px;
        font-size: 14px;
        font-weight: 400;
        letter-spacing: 0;
      }
      .button.primary { background: #111; color: #fff; }
      .button.secondary { background: #fff; color: #111; }
      @media (max-width: 760px) {
        .container { width: min(100% - 28px, 1180px); }
        .page-band { padding: 30px 0; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>

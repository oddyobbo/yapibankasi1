---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import { getBrands, getCategories, getProducts, getProjects } from "../lib/catalog.js";
import { PRODUCT_CATALOG_BASE } from "../lib/product-taxonomy-routes.js";

const [products, brands, projects, categories] = await Promise.all([
  getProducts({ limit: 8 }),
  getBrands(),
  getProjects({ limit: 3 }),
  getCategories(),
]);

const marqueeCategories = [
  ["Akustik Panel", "https://images.unsplash.com/photo-1615874959474-d609969a20ed?q=80&w=120&auto=format&fit=crop"],
  ["Banyo Mobilyası", "https://images.unsplash.com/photo-1630699156765-0f2f676f2750?q=80&w=120&auto=format&fit=crop"],
  ["Spa Çözümleri", "https://images.unsplash.com/photo-1616594039964-3f5d1b96f1f8?q=80&w=120&auto=format&fit=crop"],
  ["Yaşam Alanı Aksesuarları", "https://images.unsplash.com/photo-1519710164239-da123dc03ef4?q=80&w=120&auto=format&fit=crop"],
  ["Yemek Alanı Aksesuarları", "https://images.unsplash.com/photo-1616627458047-0f8c8f9e8d26?q=80&w=120&auto=format&fit=crop"],
  ["Masa Aksesuarları", "https://images.unsplash.com/photo-1586953208448-b95a79798f07?q=80&w=120&auto=format&fit=crop"],
  ["Duvar Kaplamaları", "https://images.unsplash.com/photo-1616046229478-9901c5536a45?q=80&w=120&auto=format&fit=crop"],
  ["Menteşeli Kapı Donanımları", "https://images.unsplash.com/photo-1600566753086-00f18fb6b3ea?q=80&w=120&auto=format&fit=crop"],
  ["Sürme Kapı Donanımları", "https://images.unsplash.com/photo-1618220179428-22790b461013?q=80&w=120&auto=format&fit=crop"],
  ["Cam Sistemleri", "https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=120&auto=format&fit=crop"],
];

const architectItems = [
  "Performans odaklı arama (NRC, yangın sınıfı, EPD)",
  "Tek tıkla PDF, DWG, BIM dosyalarına erişim",
  "Projede kullanılmış malzemeleri bağlamıyla görme",
  "Markaya doğrudan teklif veya bilgi talebi",
];

const brandItems = [
  "Tek panelden ürün ve dosya yönetimi",
  "CSV ile toplu ürün yükleme (gelişmiş plan)",
  "Lead, görüntülenme ve dönüşüm istatistikleri",
  "Editör kontrolü sonrası yayına alma",
];
---
<BaseLayout
  title="Archilink | Türkiye Mimari Malzeme Platformu"
  description="Mimarlar için teknik veriye sahip ürün keşfi. Markalar için ücretsiz başvuru, ürün yönetimi ve lead toplama altyapısı."
  canonical="/"
>
  <Header />
  <main class="home-page">
    <section id="hero-anim" class="hero-frame">
      <div id="hero-bg" class="hero-bg" aria-hidden="true">
        <img src="https://images.unsplash.com/photo-1497366811353-6870744d04b2?q=80&w=1974&auto=format&fit=crop" alt="" width="1974" height="1316" />
        <div class="hero-shade"></div>
      </div>
      <div id="hero-overlay" class="hero-overlay" aria-hidden="true"></div>
      <div id="hero-bands" class="hero-bands" aria-hidden="true">
        <div><span class="hbt">Türkiye'nin mimari</span></div>
        <div><span class="hbt">malzeme platformu.</span></div>
        <div><span class="hbt smaller">100+ marka&nbsp;&nbsp;·&nbsp;&nbsp;binlerce ürün</span></div>
        <div><span class="hbt smaller">NRC&nbsp;&nbsp;·&nbsp;&nbsp;EPD&nbsp;&nbsp;·&nbsp;&nbsp;BIM&nbsp;&nbsp;·&nbsp;&nbsp;teknik veri</span></div>
      </div>
      <div id="hero-cta" class="hero-cta">
        <p>Mimari proje için doğru malzemeyi saniyeler içinde bul.</p>
        <div>
          <a href={PRODUCT_CATALOG_BASE}>Ürünleri Keşfet →</a>
          <a href="/marka-basvuru.html">Marka Başvurusu</a>
        </div>
      </div>
    </section>

    <section class="showcase">
      <div class="showcase-inner">
        <div class="showcase-copy">
          <p class="section-kicker">Hızlı Keşif</p>
          <h1>İhtiyacın olanı bul.<br />Projeni hızla tamamla.</h1>
          <p>Yüzlerce markanın doğrulanmış teknik verisine, dosyalarına ve projelerine tek bir arama deneyiminden ulaş. Markalar için kendi paneliyle ücretsiz başlangıç.</p>
          <div class="action-row">
            <a class="solid" href={PRODUCT_CATALOG_BASE}>Keşfetmeye Başla</a>
            <a href="/marka-basvuru.html">Marka Partneri Ol</a>
          </div>
        </div>
        <div class="showcase-media">
          <img src="https://images.unsplash.com/photo-1493666438817-866a91353ca9?q=80&w=1974&auto=format&fit=crop" alt="Mimari malzeme arama deneyimi" loading="lazy" width="1974" height="1316" />
        </div>
      </div>
      <div class="cat-marquee" aria-label="Popüler kategoriler">
        <div class="cat-marquee-track">
          {[...marqueeCategories, ...marqueeCategories].map(([label, image]) => (
            <a href={`${PRODUCT_CATALOG_BASE}?q=${encodeURIComponent(label)}`} class="cat-chip">
              <img src={image} alt="" loading="lazy" width="44" height="44" />
              {label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="brand-strip">
      <div>
        <p class="section-kicker">Birlikte Çalıştığımız Markalar</p>
        <h2>Archilink, sektörün en güçlü markalarıyla çalışıyor.</h2>
        <a href="/brands">Tüm markaları gör →</a>
      </div>
      <p>{brands.length ? `${brands.length} onaylı marka yayında.` : "Onaylı marka profilleri eklendikçe burada görünecek."}</p>
    </section>

    <section class="dual-value">
      <article>
        <p class="section-kicker">Mimarlar için</p>
        <h2>Bir aramada doğru ürünü bul.</h2>
        <p>Performans, sertifika, kullanım alanı ve marka filtreleri tek arayüzde. Aramadan teknik dosyaya kadar süreç kesintisiz.</p>
        <ul>
          {architectItems.map((item, index) => (
            <li><span>{String(index + 1).padStart(2, "0")}</span>{item}</li>
          ))}
        </ul>
        <a class="solid" href={PRODUCT_CATALOG_BASE}>Aramayı dene →</a>
      </article>
      <article>
        <p class="section-kicker">Markalar için</p>
        <h2>Doğru talebe ulaş, kendi panelinden yönet.</h2>
        <p>Ürünlerini, dosyalarını ve gelen lead’leri kendi panelinden yönet. Karmaşık entegrasyon yok, demo değil; gerçek talep akışı.</p>
        <ul>
          {brandItems.map((item, index) => (
            <li><span>{String(index + 1).padStart(2, "0")}</span>{item}</li>
          ))}
        </ul>
        <a href="/marka-basvuru.html">Ücretsiz başvur →</a>
      </article>
    </section>

    <section class="catalog-band">
      <div class="section-head">
        <div>
          <p class="section-kicker">Keşif</p>
          <h2>Öne çıkan kategoriler</h2>
        </div>
        <a href="/categories">Tüm kategoriler →</a>
      </div>
      <CategoryGrid categories={categories.slice(0, 8)} />
    </section>

    <section class="product-band">
      <div class="section-head">
        <div>
          <p class="section-kicker">Öne çıkan</p>
          <h2>Bu hafta keşfedilen ürünler</h2>
        </div>
        <a href={PRODUCT_CATALOG_BASE}>Tüm ürünler →</a>
      </div>
      {products.length ? <div class="grid cards">{products.map((product) => <ProductCard product={product} />)}</div> : <p class="empty">Henüz yayınlanmış ürün yok.</p>}
    </section>

    <section class="story-band">
      <div class="story-card">
        <div class="story-media">
          <img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=1974&auto=format&fit=crop" alt="" loading="lazy" width="1974" height="1316" />
        </div>
        <div>
          <p class="section-kicker">Müşteri Hikâyesi</p>
          <blockquote>"Archilink sayesinde malzeme araştırma süremiz dramatik şekilde düştü. Doğrulanmış teknik veri ve dosya erişimi tek yerde."</blockquote>
          <p class="person"><strong>Ekin Demir</strong> <span>· Senior Architect</span></p>
          <div class="stats">
            <div>
              <strong>65%</strong>
              <span>Daha kısa malzeme araştırma süresi</span>
            </div>
            <div>
              <strong>98%</strong>
              <span>Teknik veri doğrulama oranı</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="closing-cta">
      <h2>Bugün arama yap.<br />Yarın doğru malzemeyle inşa et.</h2>
      <p>Archilink, Türkiye’nin en hızlı büyüyen mimari malzeme topluluğu. Mimarlar ve markalar için aynı doğru kaynak.</p>
      <div>
        <a href={PRODUCT_CATALOG_BASE}>Ürünleri Keşfet</a>
        <a href="/marka-basvuru.html">Marka Başvurusu</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  (() => {
    const heroEl = document.getElementById("hero-anim");
    const heroBg = document.getElementById("hero-bg");
    const heroOverlay = document.getElementById("hero-overlay");
    const heroBands = document.getElementById("hero-bands");
    const heroCta = document.getElementById("hero-cta");
    const texts = document.querySelectorAll(".hbt");
    if (!heroEl || !heroBg || !heroOverlay || !heroBands || !heroCta || !texts.length) return;

    setTimeout(() => {
      const sR = heroEl.getBoundingClientRect();
      const vw = window.innerWidth;
      const hy = heroEl.offsetHeight;
      const s = 0.58;
      const lx = vw >= 1024 ? 40 : vw >= 640 ? 24 : 16;
      const gx = 20;
      const gy = 10;
      const bot = 160;
      const rects = Array.from(texts).map((text) => text.getBoundingClientRect());
      const tw = Array.from(texts).map((text) => text.offsetWidth);
      const th = Array.from(texts).map((text) => text.offsetHeight);
      const r1h = th[0] * s;
      const r2h = th[2] * s;
      const r1y = hy - bot - r1h - gy - r2h;
      const r2y = hy - bot - r2h;
      const finalX = [lx, lx + tw[0] * s + gx, lx, lx + tw[2] * s + gx];
      const finalY = [r1y, r1y, r2y, r2y];

      texts.forEach((text, index) => {
        const rect = rects[index];
        const localX = rect.left - sR.left;
        const localY = rect.top - sR.top;
        text.style.animation = "none";
        text.style.clipPath = "none";
        text.style.position = "absolute";
        text.style.top = "0";
        text.style.left = "0";
        text.style.zIndex = "3";
        text.style.transformOrigin = "0 0";
        text.style.transform = `translateX(${localX}px) translateY(${localY}px) scale(1)`;
        heroEl.appendChild(text);
      });

      heroBg.style.opacity = "1";
      heroBg.style.transform = "scale(1)";
      heroBands.style.opacity = "0";
      heroCta.style.left = `${lx}px`;
      heroCta.style.top = `${r2y + r2h + 22}px`;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          texts.forEach((text, index) => {
            text.style.transition = "transform 1.1s cubic-bezier(.77,0,.18,1), color .7s ease";
            text.style.color = "#fff";
            text.style.transform = `translateX(${finalX[index]}px) translateY(${finalY[index]}px) scale(${s})`;
          });
          heroOverlay.style.opacity = "0";
        });
      });

      setTimeout(() => {
        heroCta.style.opacity = "1";
        heroCta.style.transform = "translateY(0)";
      }, 1000);
    }, 2000);
  })();
</script>

<style>
  .home-page {
    background: #fff;
    color: #0b0b0c;
    overflow-x: hidden;
  }
  .hero-frame {
    position: relative;
    height: 72vh;
    min-height: 560px;
    margin: 12px 16px 16px;
    overflow: hidden;
    border-radius: 28px;
    background: #fff;
  }
  .hero-bg,
  .hero-overlay,
  .hero-bands {
    position: absolute;
    inset: 0;
  }
  .hero-bg {
    z-index: 0;
    opacity: 0;
    transform: scale(1.06);
    transition: opacity 1.2s ease, transform 7s ease;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(0,0,0,.76) 0%, rgba(0,0,0,.4) 60%, rgba(0,0,0,.18) 100%);
  }
  .hero-overlay {
    z-index: 1;
    background: #fff;
    pointer-events: none;
    transition: opacity 1.1s ease;
  }
  .hero-bands {
    z-index: 2;
    display: flex;
    flex-direction: column;
    transition: opacity .5s ease;
  }
  .hero-bands > div {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid rgba(0,0,0,.1);
  }
  .hero-bands > div:last-child {
    border-bottom: 0;
  }
  .hbt {
    white-space: nowrap;
    font-size: clamp(24px, 5vw, 80px);
    font-weight: 200;
    letter-spacing: 0;
    color: #0b0b0c;
    animation: hbt-in .82s cubic-bezier(.22,1,.36,1) .18s both;
  }
  .hbt.smaller {
    font-size: clamp(20px, 4.2vw, 66px);
    font-weight: 100;
  }
  .hero-bands > div:nth-child(2) .hbt { animation-delay: .38s; }
  .hero-bands > div:nth-child(3) .hbt { animation-delay: .58s; }
  .hero-bands > div:nth-child(4) .hbt { animation-delay: .78s; }
  .hero-cta {
    position: absolute;
    z-index: 4;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .hero-cta p {
    margin: 0 0 14px;
    color: rgba(255,255,255,.65);
    font-size: 14px;
    font-weight: 300;
  }
  .hero-cta div,
  .action-row,
  .closing-cta div {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hero-cta a,
  .action-row a,
  .dual-value article > a,
  .brand-strip a,
  .closing-cta a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 24px;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0;
  }
  .hero-cta a:first-child,
  .closing-cta a:first-child {
    background: #fff;
    color: #0b0b0c;
  }
  .hero-cta a:last-child,
  .closing-cta a:last-child {
    border: 1.5px solid rgba(255,255,255,.35);
    color: #fff;
  }
  .showcase {
    border-bottom: 1px solid rgba(0,0,0,.08);
    background: #fff;
  }
  .showcase-inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px;
    align-items: stretch;
    padding: 72px 40px 8px;
  }
  .showcase-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-radius: 20px;
    background: #f5f5f7;
    padding: 40px;
  }
  .section-kicker {
    margin: 0;
    color: #6e6e73;
    font-size: 12px;
    line-height: 1.4;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
  }
  .showcase-copy h1,
  .brand-strip h2,
  .dual-value h2,
  .section-head h2,
  .closing-cta h2 {
    margin: 14px 0 0;
    color: #0b0b0c;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.05;
  }
  .showcase-copy h1 {
    font-size: clamp(38px, 5vw, 56px);
  }
  .showcase-copy > p:last-of-type,
  .dual-value article > p:not(.section-kicker),
  .closing-cta p {
    color: #6e6e73;
    font-size: 18px;
    line-height: 1.65;
  }
  .showcase-copy > p:last-of-type {
    max-width: 52ch;
    margin: 24px 0 0;
  }
  .action-row {
    margin-top: 32px;
  }
  .action-row a,
  .dual-value article > a {
    border: 1px solid rgba(0,0,0,.12);
    color: #0b0b0c;
  }
  .action-row a.solid,
  .dual-value article > a.solid {
    border-color: #0b0b0c;
    background: #0b0b0c;
    color: #fff;
  }
  .showcase-media {
    min-height: 420px;
    overflow: hidden;
    border-radius: 20px;
  }
  .showcase-media img,
  .story-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cat-marquee {
    margin-top: 32px;
    overflow: hidden;
    border-top: 1px solid rgba(0,0,0,.08);
    border-bottom: 1px solid rgba(0,0,0,.08);
    background: #fff;
  }
  .cat-marquee-track {
    display: flex;
    width: max-content;
    gap: 12px;
    padding: 10px 0;
    animation: cat-scroll 36s linear infinite;
  }
  .cat-marquee-track:hover {
    animation-play-state: paused;
  }
  .cat-chip {
    display: inline-flex;
    height: 42px;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 10px;
    background: #fff;
    padding: 0 18px;
    color: #1d1d1f;
    font-size: 14px;
    font-weight: 400;
    white-space: nowrap;
  }
  .cat-chip img {
    width: 22px;
    height: 22px;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 5px;
    object-fit: cover;
  }
  .brand-strip {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 48px;
    align-items: center;
    background: #0b0b0c;
    color: #fff;
    padding: 80px clamp(32px, 6vw, 80px);
  }
  .brand-strip h2 {
    max-width: 640px;
    color: #fff;
    font-size: clamp(30px, 4vw, 40px);
  }
  .brand-strip a {
    margin-top: 26px;
    border: 1px solid rgba(255,255,255,.25);
    color: #fff;
  }
  .brand-strip > p {
    justify-self: end;
    max-width: 420px;
    color: rgba(255,255,255,.62);
    font-size: 17px;
    line-height: 1.6;
  }
  .dual-value {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 64px;
    border-bottom: 1px solid rgba(0,0,0,.08);
    padding: 96px clamp(32px, 6vw, 80px);
  }
  .dual-value h2,
  .section-head h2 {
    font-size: clamp(34px, 4vw, 48px);
  }
  .dual-value article > p:not(.section-kicker) {
    margin: 20px 0 0;
    font-size: 16px;
  }
  .dual-value ul {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
    border-top: 1px solid rgba(0,0,0,.08);
  }
  .dual-value li {
    display: flex;
    gap: 18px;
    align-items: center;
    border-bottom: 1px solid rgba(0,0,0,.08);
    padding: 16px 0;
    color: #1d1d1f;
    font-size: 16px;
    font-weight: 400;
  }
  .dual-value li span {
    width: 42px;
    flex: 0 0 auto;
    color: #6e6e73;
    font-size: 12px;
  }
  .dual-value article > a {
    margin-top: 32px;
  }
  .catalog-band,
  .product-band,
  .story-band {
    border-bottom: 1px solid rgba(0,0,0,.08);
    padding: 96px clamp(32px, 6vw, 80px);
  }
  .catalog-band {
    background: #fafafa;
  }
  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
  }
  .section-head > a {
    color: #6e6e73;
    font-size: 14px;
  }
  .story-card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 40px;
    align-items: center;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 28px;
    background: #fafafa;
    padding: 40px;
  }
  .story-media {
    height: 420px;
    overflow: hidden;
    border-radius: 20px;
  }
  blockquote {
    margin: 18px 0 0;
    color: #0b0b0c;
    font-size: clamp(22px, 2.5vw, 28px);
    line-height: 1.28;
    font-weight: 500;
  }
  .person {
    margin: 22px 0 0;
    font-size: 14px;
  }
  .person span {
    color: #6e6e73;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 40px;
    border-top: 1px solid rgba(0,0,0,.08);
    margin-top: 32px;
    padding-top: 24px;
  }
  .stats strong {
    display: block;
    color: #0b0b0c;
    font-size: 44px;
    line-height: 1;
    font-weight: 600;
  }
  .stats span {
    display: block;
    margin-top: 10px;
    color: #6e6e73;
    font-size: 13px;
    line-height: 1.4;
  }
  .closing-cta {
    display: grid;
    justify-items: center;
    background:

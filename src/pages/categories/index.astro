---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CategoryGrid from "../../components/CategoryGrid.astro";
import { getCategories } from "../../lib/catalog.js";

const categories = await getCategories();
---
<BaseLayout
  title="Kategoriler | Archilink"
  description="Mimari ürün kategorilerini keşfet."
  canonical="/categories"
>
  <Header />
  <main>
    <section class="category-hero page-band">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Kategoriler</p>
          <h1 class="page-title">Malzemeyi doğru sınıftan keşfet.</h1>
          <p class="lead">Kategori sayfaları ürün kataloğunu SEO dostu, filtrelenebilir ve mimari karar akışına uygun şekilde böler.</p>
        </div>
        <aside class="hero-panel">
          <strong>{categories.length}</strong>
          <span>yayınlanmış kategori</span>
          <a href="/urunler" class="button secondary">Tüm ürünleri gör</a>
        </aside>
      </div>
    </section>

    <section class="page-band category-list-band">
      <div class="container">
        <div class="section-head">
          <div>
            <p class="eyebrow">Katalog sınıfları</p>
            <h2 class="section-title">Ürün kategorileri</h2>
          </div>
          <p>Kategori detayları aynı Astro şablonundan gelir; eksik veri varsa temiz boş durum gösterilir.</p>
        </div>
        <CategoryGrid categories={categories} />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
<style>
  .category-hero {
    background:
      radial-gradient(circle at 72% 18%, rgba(0,0,0,.06), transparent 26%),
      linear-gradient(180deg, #fff 0%, #f5f5f7 100%);
    border-bottom: 1px solid rgba(0,0,0,.08);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 34px;
    align-items: end;
  }
  .hero-panel {
    border: 1px solid rgba(0,0,0,.1);
    border-radius: 22px;
    background: rgba(255,255,255,.75);
    padding: 20px;
    backdrop-filter: blur(18px);
  }
  .hero-panel strong {
    display: block;
    font-size: 46px;
    line-height: 1;
    font-weight: 500;
  }
  .hero-panel span {
    display: block;
    margin: 8px 0 18px;
    color: #6e6e73;
    font-size: 14px;
  }
  .category-list-band { background: #fff; }
  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 28px;
    align-items: end;
    margin-bottom: 22px;
  }
  .section-head p:last-child {
    max-width: 420px;
    margin: 0;
    color: #6e6e73;
    font-size: 14px;
    line-height: 1.55;
  }
  @media (max-width: 860px) {
    .hero-grid,
    .section-head {
      display: grid;
      grid-template-columns: 1fr;
    }
    .hero-panel { max-width: 420px; }
  }
</style>

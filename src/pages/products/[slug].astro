---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProductGallery from "../../components/ProductGallery.astro";
import TechnicalSpecs from "../../components/TechnicalSpecs.astro";
import DownloadFiles from "../../components/DownloadFiles.astro";
import RelatedProducts from "../../components/RelatedProducts.astro";
import RelatedProjects from "../../components/RelatedProjects.astro";
import RequestQuoteCTA from "../../components/RequestQuoteCTA.astro";
import BrandSummaryCard from "../../components/BrandSummaryCard.astro";
import { getProductDetail, imageForProduct } from "../../lib/catalog.js";
import { productPath } from "../../lib/slugs.js";

const product = await getProductDetail(Astro.params.slug);
if (!product) return Astro.redirect("/products", 302);
const brand = product.brand || null;
const categoryLabel = [
  product.categoryRecord?.name || "",
  product.subcategoryRecord?.name || "",
].filter(Boolean).join(" / ") || product.category || "Kategori belirtilmedi";
const description = product.description || product.summary || "";
const usageValues = [
  product.usage_area,
  product.indoor_outdoor,
  product.acoustic_rating,
  product.color_family,
].filter(Boolean);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  image: imageForProduct(product) ? [imageForProduct(product)] : undefined,
  description: product.summary || product.description,
  brand: (brand?.name || product.brand_name) ? { "@type": "Brand", name: brand?.name || product.brand_name } : undefined,
  sku: product.sku || undefined,
  category: categoryLabel || undefined,
};
---
<BaseLayout
  title={`${product.name} | ${brand?.name || product.brand_name || "Archilink"} | Archilink`}
  description={product.summary || product.description || `${product.name} teknik bilgileri, dosyaları ve marka detayları.`}
  canonical={productPath(product)}
  image={imageForProduct(product)}
  type="product"
  jsonLd={jsonLd}
>
  <Header />
  <main class="product-detail-page">
    <div class="product-detail-layout-shell">
      <div class="product-detail-layout">
        <section class="product-detail-main">
          <article class="product-detail-section product-detail-hero-panel">
            <ProductGallery product={product} />
          </article>

          <div class="product-detail-heading">
            <p class="product-detail-hero-kicker">{categoryLabel}</p>
          </div>

          <section class="product-detail-section product-detail-description-block">
            <h2>Ürün Açıklaması</h2>
            <p>{description || "Bu ürün için açıklama henüz eklenmedi."}</p>
          </section>

          <TechnicalSpecs product={product} />

          <section class="product-detail-section variants-section">
            <div class="section-title-row">
              <h2>Varyantlar</h2>
              {product.variants?.length ? <span>{product.variants.length}</span> : null}
            </div>
            {product.variants?.length ? (
              <div class="variant-grid">
                {product.variants.map((variant) => (
                  <article class="variant">
                    <strong>{variant.name || "Varyant"}</strong>
                    <span>{[variant.finish, variant.size, variant.material].filter(Boolean).join(" · ") || "Detay bilgisi eklenmedi."}</span>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty-line">Bu ürün için varyant bilgisi henüz eklenmedi.</p>
            )}
          </section>

          <section class="info-grid">
            <DownloadFiles product={product} />
            <article class="product-detail-section usage-card">
              <h2>Kullanım Alanları</h2>
              {usageValues.length ? (
                <ul>{usageValues.map((item) => <li>{item}</li>)}</ul>
              ) : (
                <p class="empty-line">Kullanım alanı bilgisi henüz eklenmedi.</p>
              )}
            </article>
          </section>

          <section class="info-grid">
            <RelatedProjects projects={product.relatedProjects || []} />
            <RequestQuoteCTA product={product} />
          </section>
        </section>

        <aside class="product-detail-sticky-aside">
          <BrandSummaryCard product={product} brand={brand} categoryLabel={categoryLabel} relatedProducts={product.relatedProducts || []} />
        </aside>
      </div>
    </div>

    <RelatedProducts products={product.relatedProducts || []} />
  </main>
  <Footer />
</BaseLayout>
<style>
  .product-detail-page {
    background: #fafafa;
    color: #0d0d0f;
  }
  .product-detail-layout-shell {
    max-width: none;
    padding: 0 0 68px;
  }
  .product-detail-layout {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 440px);
    gap: 0;
    align-items: start;
  }
  .product-detail-main {
    grid-column: 1 / -1;
    grid-row: 1;
    display: grid;
    gap: 18px;
    min-width: 0;
  }
  .product-detail-section {
    width: min(calc(100% - 520px), 1120px);
    margin-left: 36px;
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 22px;
    background: #fff;
    padding: 28px;
    box-shadow: 0 1px 0 rgba(0,0,0,.02);
  }
  .product-detail-section.product-detail-hero-panel {
    width: auto;
    margin-left: 0;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }
  .product-detail-heading {
    width: min(calc(100% - 520px), 1120px);
    margin: 18px 0 0 36px;
  }
  .product-detail-hero-kicker {
    margin: 0;
    color: #6e6e73;
    font-size: 15px;
    line-height: 1.45;
    font-weight: 400;
  }
  .product-detail-description-block h2,
  .variants-section h2,
  .usage-card h2 {
    margin: 0 0 14px;
    color: #1d1d1f;
    font-size: 20px;
    line-height: 1.22;
    font-weight: 600;
    letter-spacing: 0;
  }
  .product-detail-description-block p,
  .empty-line {
    margin: 0;
    max-width: 820px;
    color: #424245;
    font-size: 15px;
    line-height: 1.7;
  }
  .section-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }
  .section-title-row h2 {
    margin: 0;
  }
  .section-title-row span {
    min-width: 32px;
    min-height: 26px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: #f5f5f7;
    color: #333;
    font-size: 13px;
  }
  .variant-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 12px;
  }
  .variant {
    display: grid;
    gap: 8px;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 14px;
    padding: 16px;
    background: #fff;
  }
  .variant strong {
    font-size: 14px;
    font-weight: 600;
  }
  .variant span {
    color: #6e6e73;
    font-size: 13px;
    line-height: 1.45;
  }
  .info-grid {
    width: min(calc(100% - 520px), 1120px);
    margin-left: 36px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 1fr);
    gap: 18px;
  }
  .info-grid > :global(section),
  .info-grid > :global(div),
  .info-grid > article {
    width: auto;
    margin-left: 0;
  }
  .usage-card ul {
    list-style: none;
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
  }
  .usage-card li {
    min-height: 40px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(0,0,0,.07);
    color: #424245;
    font-size: 14px;
  }
  .product-detail-sticky-aside {
    grid-column: 2;
    grid-row: 1;
    z-index: 8;
    position: sticky;
    top: 78px;
    align-self: start;
    width: min(408px, calc(100% - 36px));
    max-height: calc(100vh - 112px);
    overflow: auto;
    justify-self: end;
    margin-top: clamp(220px, 27vw, 330px);
    margin-right: 36px;
  }
  @media (max-width: 1099px) {
    .product-detail-layout {
      grid-template-columns: 1fr;
    }
    .product-detail-main,
    .product-detail-sticky-aside {
      grid-column: 1;
      grid-row: auto;
    }
    .product-detail-sticky-aside {
      position: static;
      order: -1;
      width: auto;
      max-height: none;
      margin: 18px;
    }
    .product-detail-heading,
    .product-detail-section,
    .info-grid {
      width: auto;
      margin-left: 18px;
      margin-right: 18px;
    }
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .product-detail-section {
      padding: 22px;
    }
  }
</style>

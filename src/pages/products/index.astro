---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProductCard from "../../components/ProductCard.astro";
import { getProductFilterOptions, getProductListPage } from "../../lib/catalog.js";

const params = Astro.url.searchParams;
const filters = {
  search: params.get("q") || "",
  brand: params.get("brand") || "",
  category: params.get("category") || "",
  material: params.get("material") || "",
  usageArea: params.get("usageArea") || "",
  colorFamily: params.get("colorFamily") || "",
  fireClass: params.get("fireClass") || "",
  indoorOutdoor: params.get("indoorOutdoor") || "",
  country: params.get("country") || "",
  city: params.get("city") || "",
  role: params.get("role") || "",
  sort: params.get("sort") || "created_desc",
  hasPdf: params.get("hasPdf") === "1",
  hasCad: params.get("hasCad") === "1",
  hasBim: params.get("hasBim") === "1",
};
const page = Number(params.get("page") || 1);
const [result, options] = await Promise.all([
  getProductListPage({ filters, page }),
  getProductFilterOptions(),
]);
const { products, count, hasPrevious, hasNext } = result;

const withParam = (key, value) => {
  const next = new URLSearchParams(params);
  next.delete("page");
  if (value === "" || value == null || value === false) next.delete(key);
  else next.set(key, String(value));
  const query = next.toString();
  return query ? `/products?${query}` : "/products";
};
const pageHref = (targetPage) => {
  const next = new URLSearchParams(params);
  if (targetPage <= 1) next.delete("page");
  else next.set("page", String(targetPage));
  const query = next.toString();
  return query ? `/products?${query}` : "/products";
};
const clearHref = (key) => withParam(key, "");
const categoryPills = ["Tümü", ...options.categories.slice(0, 12)];
const activeChips = [
  filters.search && ["Arama", filters.search, "q"],
  filters.brand && ["Marka", filters.brand, "brand"],
  filters.category && ["Kategori", filters.category, "category"],
  filters.material && ["Malzeme", filters.material, "material"],
  filters.usageArea && ["Kullanım", filters.usageArea, "usageArea"],
  filters.colorFamily && ["Renk", filters.colorFamily, "colorFamily"],
  filters.fireClass && ["Yangın", filters.fireClass, "fireClass"],
  filters.indoorOutdoor && ["Mekan", filters.indoorOutdoor, "indoorOutdoor"],
  filters.city && ["Şehir", filters.city, "city"],
  filters.role && ["Rol", filters.role, "role"],
  filters.hasPdf && ["Dosya", "PDF", "hasPdf"],
  filters.hasCad && ["Dosya", "CAD", "hasCad"],
  filters.hasBim && ["Dosya", "BIM", "hasBim"],
].filter(Boolean);
const facetGroups = [
  ["Marka", "brand", options.brands],
  ["Kategori", "category", options.categories],
  ["Malzeme", "material", options.materials],
  ["Kullanım alanı", "usageArea", options.usageAreas],
  ["Renk ailesi", "colorFamily", options.colorFamilies],
  ["Yangın sınıfı", "fireClass", options.fireClasses],
  ["Şehir", "city", options.cities],
  ["Rol", "role", options.roles],
].filter(([, , values]) => values.length);
---
<BaseLayout
  title="Ürünler | Archilink"
  description="Akustik, aydınlatma, dış cephe, zemin ve daha fazlası. Teknik filtrelerle doğru mimari malzemeyi saniyeler içinde bul."
  canonical="/products"
>
  <Header />
  <main class="products-page">
    <section class="top-filter-bar">
      <form class="search-row" method="get" action="/products">
        <label class="search-field">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <input name="q" value={filters.search} placeholder="Ürün, marka veya anahtar kelime ara..." autocomplete="off" />
        </label>
        <input type="hidden" name="brand" value={filters.brand} />
        <input type="hidden" name="category" value={filters.category} />
        <input type="hidden" name="material" value={filters.material} />
        <input type="hidden" name="usageArea" value={filters.usageArea} />
        <input type="hidden" name="colorFamily" value={filters.colorFamily} />
        <input type="hidden" name="fireClass" value={filters.fireClass} />
        <input type="hidden" name="indoorOutdoor" value={filters.indoorOutdoor} />
        <input type="hidden" name="city" value={filters.city} />
        <input type="hidden" name="role" value={filters.role} />
        <input type="hidden" name="sort" value={filters.sort} />
        {filters.hasPdf && <input type="hidden" name="hasPdf" value="1" />}
        {filters.hasCad && <input type="hidden" name="hasCad" value="1" />}
        {filters.hasBim && <input type="hidden" name="hasBim" value="1" />}
      </form>

      <div class="tool-row">
        <a class="filter-button" href="#filters">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16"></path>
            <circle cx="16" cy="6" r="2.5"></circle>
            <circle cx="8" cy="12" r="2.5"></circle>
            <circle cx="16" cy="18" r="2.5"></circle>
          </svg>
          Filtreler
        </a>
        <nav class="category-pills" aria-label="Kategori filtreleri">
          {categoryPills.map((category) => {
            const isAll = category === "Tümü";
            const active = isAll ? !filters.category : filters.category === category;
            return (
              <a class:list={["cat-pill", active && "active"]} href={isAll ? clearHref("category") : withParam("category", category)}>
                <span>{category}</span>
              </a>
            );
          })}
        </nav>
        <form class="sort-form" method="get" action="/products">
          <input type="hidden" name="q" value={filters.search} />
          <input type="hidden" name="brand" value={filters.brand} />
          <input type="hidden" name="category" value={filters.category} />
          <input type="hidden" name="material" value={filters.material} />
          <input type="hidden" name="usageArea" value={filters.usageArea} />
          <input type="hidden" name="colorFamily" value={filters.colorFamily} />
          <input type="hidden" name="fireClass" value={filters.fireClass} />
          <input type="hidden" name="indoorOutdoor" value={filters.indoorOutdoor} />
          <input type="hidden" name="city" value={filters.city} />
          <input type="hidden" name="role" value={filters.role} />
          {filters.hasPdf && <input type="hidden" name="hasPdf" value="1" />}
          {filters.hasCad && <input type="hidden" name="hasCad" value="1" />}
          {filters.hasBim && <input type="hidden" name="hasBim" value="1" />}
          <label>
            <span>Sırala</span>
            <select name="sort" onchange="this.form.submit()">
              <option value="created_desc" selected={filters.sort === "created_desc"}>Yeni eklenenler</option>
              <option value="name_asc" selected={filters.sort === "name_asc"}>İsme göre A-Z</option>
              <option value="name_desc" selected={filters.sort === "name_desc"}>İsme göre Z-A</option>
              <option value="brand_asc" selected={filters.sort === "brand_asc"}>Markaya göre</option>
            </select>
          </label>
        </form>
      </div>

      {activeChips.length > 0 && (
        <div class="chips-row">
          <span>Aktif:</span>
          {activeChips.map(([label, value, key]) => (
            <a class="active-chip" href={clearHref(key)}>
              {label}: {value}
              <span aria-hidden="true">×</span>
            </a>
          ))}
          <a class="clear-all" href="/products">Tümünü Temizle</a>
        </div>
      )}
    </section>

    <div class="products-content-row">
      <aside id="filters" class="filter-sidebar">
        <form method="get" action="/products">
          <div class="sidebar-head">
            <h1>Ürünler</h1>
            <p>{count} ürün bulundu</p>
          </div>
          <input type="hidden" name="q" value={filters.search} />
          <input type="hidden" name="sort" value={filters.sort} />

          <div class="sidebar-search">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input type="search" placeholder="Filtre ara..." aria-label="Filtre ara" />
          </div>

          <div class="quick-toggles">
            <label><span>PDF var</span><input type="checkbox" name="hasPdf" value="1" checked={filters.hasPdf} /></label>
            <label><span>CAD var</span><input type="checkbox" name="hasCad" value="1" checked={filters.hasCad} /></label>
            <label><span>BIM var</span><input type="checkbox" name="hasBim" value="1" checked={filters.hasBim} /></label>
          </div>

          <details class="acc-group" open>
            <summary>İç / dış mekan <span>⌄</span></summary>
            <div class="acc-body">
              <label class="choice"><input type="radio" name="indoorOutdoor" value="" checked={!filters.indoorOutdoor} /> Tümü</label>
              <label class="choice"><input type="radio" name="indoorOutdoor" value="indoor" checked={filters.indoorOutdoor === "indoor"} /> İç mekan</label>
              <label class="choice"><input type="radio" name="indoorOutdoor" value="outdoor" checked={filters.indoorOutdoor === "outdoor"} /> Dış mekan</label>
              <label class="choice"><input type="radio" name="indoorOutdoor" value="both" checked={filters.indoorOutdoor === "both"} /> İç + dış</label>
            </div>
          </details>

          {facetGroups.map(([label, key, values], index) => (
            <details class="acc-group" open={index < 5}>
              <summary>{label} <span>⌄</span></summary>
              <div class="acc-body">
                <label class="choice"><input type="radio" name={key} value="" checked={!filters[key]} /> Tümü</label>
                {values.slice(0, 24).map((value) => (
                  <label class="choice">
                    <input type="radio" name={key} value={value} checked={filters[key] === value} />
                    {value}
                  </label>
                ))}
              </div>
            </details>
          ))}

          <div class="sidebar-actions">
            <button type="submit">Filtrele</button>
            <a href="/products">Temizle</a>
          </div>
        </form>
      </aside>

      <section class="products-grid-wrapper" aria-labelledby="products-heading">
        <div class="catalog-head">
          <div>
            <p>Katalog</p>
            <h2 id="products-heading">Mimari ürün kataloğu</h2>
          </div>
          <p>{count} ürün · Sayfa {result.page}</p>
        </div>

        {products.length ? (
          <div class="product-grid">
            {products.map((product) => <ProductCard product={product} />)}
          </div>
        ) : (
          <p class="empty">Arama kriterlerine uygun ürün bulunamadı.</p>
        )}

        {(hasPrevious || hasNext) && (
          <nav class="pagination" aria-label="Ürün sayfaları">
            {hasPrevious ? <a href={pageHref(result.page - 1)}>Önceki</a> : <span></span>}
            {hasNext ? <a href={pageHref(result.page + 1)}>Sonraki</a> : <span></span>}
          </nav>
        )}
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .products-page {
    min-height: 100vh;
    background: #fff;
    color: #0b0b0c;
  }
  .top-filter-bar {
    position: sticky;
    top: 72px;
    z-index: 12;
    border-bottom: 1px solid rgba(0,0,0,.06);
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }
  .search-row {
    display: flex;
    gap: 8px;
    padding: 12px 40px 8px;
  }
  .search-field {
    position: relative;
    flex: 1;
  }
  .search-field svg,
  .sidebar-search svg,
  .filter-button svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .search-field svg {
    position: absolute;
    left: 14px;
    top: 50%;
    width: 15px;
    height: 15px;
    color: #8e8e93;
    transform: translateY(-50%);
    pointer-events: none;
  }
  .search-field input {
    width: 100%;
    height: 42px;
    border: 1px solid rgba(0,0,0,.14);
    border-radius: 999px;
    background: #f5f5f7;
    padding: 0 18px 0 42px;
    color: #0b0b0c;
    font: inherit;
    font-size: 16px;
    outline: none;
    transition: background .18s ease, border-color .18s ease;
  }
  .search-field input:focus {
    border-color: rgba(0,0,0,.25);
    background: #fff;
  }
  .tool-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 40px 10px;
  }
  .filter-button {
    display: inline-flex;
    height: 34px;
    flex: 0 0 auto;
    align-items: center;
    gap: 7px;
    border: 1px solid rgba(0,0,0,.14);
    border-radius: 999px;
    padding: 0 13px;
    color: #1d1d1f;
    font-size: 12px;
    font-weight: 400;
  }
  .filter-button svg {
    width: 13px;
    height: 13px;
  }
  .filter-button circle {
    fill: currentColor;
    stroke: none;
  }
  .category-pills {
    display: flex;
    flex: 1;
    min-width: 0;
    gap: 8px;
    overflow-x: auto;
    padding: 2px 0;
    scrollbar-width: none;
  }
  .category-pills::-webkit-scrollbar {
    display: none;
  }
  .cat-pill {
    display: inline-flex;
    height: 34px;
    flex: 0 0 auto;
    align-items: center;
    border: 1px solid transparent;
    border-radius: 999px;
    background: #f2f2f7;
    padding: 0 14px;
    color: #3a3a3c;
    font-size: 13px;
    font-weight: 400;
    white-space: nowrap;
    transition: background .15s ease, color .15s ease;
  }
  .cat-pill:hover {
    background: #e5e5ea;
  }
  .cat-pill.active {
    background: #0b0b0c;
    color: #fff;
  }
  .sort-form {
    flex: 0 0 auto;
  }
  .sort-form label {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sort-form span {
    color: #6e6e73;
    font-size: 12px;
  }
  .sort-form select {
    height: 34px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 999px;
    background: #fff;
    padding: 0 30px 0 12px;
    color: #1d1d1f;
    font: inherit;
    font-size: 12px;
    outline: none;
  }
  .chips-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 7px;
    padding: 0 40px 12px;
  }
  .chips-row > span {
    color: #8e8e93;
    font-size: 11px;
  }
  .active-chip {
    display: inline-flex;
    height: 26px;
    align-items: center;
    gap: 6px;
    border-radius: 999px;
    background: #f0f0f5;
    padding: 0 8px 0 10px;
    color: #1d1d1f;
    font-size: 12px;
  }
  .active-chip span {
    display: inline-grid;
    width: 15px;
    height: 15px;
    place-items: center;
    border-radius: 999px;
    background: #c7c7cc;
    color: #fff;
    font-size: 10px;
    line-height: 1;
  }
  .clear-all {
    color: #0b0b0c;
    font-size: 11px;
    text-decoration: underline;
  }
  .products-content-row {
    display: flex;
    align-items: flex-start;
  }
  .filter-sidebar {
    position: sticky;
    top: 154px;
    width: 300px;
    height: calc(100vh - 154px);
    flex: 0 0 300px;
    overflow-y: auto;
    border-right: 1px solid rgba(0,0,0,.06);
    background: #fff;
  }
  .filter-sidebar form {
    padding: 24px 16px;
  }
  .sidebar-head h1 {
    margin: 0;
    color: #0b0b0c;
    font-size: 22px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: 0;
  }
  .sidebar-head p {
    margin: 6px 0 0;
    color: #6e6e73;
    font-size: 13px;
  }
  .sidebar-search {
    position: relative;
    margin: 18px 0 16px;
  }
  .sidebar-search svg {
    position: absolute;
    left: 10px;
    top: 50%;
    width: 12px;
    height: 12px;
    color: #8e8e93;
    transform: translateY(-50%);
  }
  .sidebar-search input {
    width: 100%;
    height: 34px;
    border: 1px solid #e5e5ea;
    border-radius: 8px;
    background: #fafafa;
    padding: 0 10px 0 30px;
    color: #111;
    font: inherit;
    font-size: 12px;
    outline: none;
  }
  .quick-toggles {
    display: grid;
    gap: 10px;
    border-bottom: 1px solid rgba(0,0,0,.06);
    margin-bottom: 8px;
    padding-bottom: 14px;
  }
  .quick-toggles label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #3a3a3c;
    font-size: 12.5px;
  }
  .quick-toggles input,
  .choice input {
    width: 15px;
    height: 15px;
    accent-color: #0b0b0c;
  }
  .acc-group {
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .acc-group summary {
    display: flex;
    min-height: 42px;
    cursor: pointer;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    color: #1d1d1f;
    font-size: 13px;
    font-weight: 500;
  }
  .acc-group summary::-webkit-details-marker {
    display: none;
  }
  .acc-group summary span {
    color: #8e8e93;
    font-size: 14px;
    transition: transform .18s ease;
  }
  .acc-group[open] summary span {
    transform: rotate(180deg);
  }
  .acc-body {
    display: grid;
    max-height: 290px;
    gap: 9px;
    overflow-y: auto;
    padding: 0 0 14px;
  }
  .choice {
    display: flex;
    align-items: center;
    gap: 9px;
    color: #3a3a3c;
    font-size: 12.5px;
    line-height: 1.35;
  }
  .sidebar-actions {
    position: sticky;
    bottom: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    background: linear-gradient(180deg, rgba(255,255,255,.74), #fff 26%);
    margin-top: 16px;
    padding-top: 16px;
  }
  .sidebar-actions button,
  .sidebar-actions a {
    display: inline-flex;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font: inherit;
    font-size: 13px;
    font-weight: 400;
  }
  .sidebar-actions button {
    border: 1px solid #0b0b0c;
    background: #0b0b0c;
    color: #fff;
  }
  .sidebar-actions a {
    border: 1px solid rgba(0,0,0,.14);
    color: #1d1d1f;
  }
  .products-grid-wrapper {
    flex: 1;
    min-width: 0;
    padding: 28px 40px 56px;
  }
  .catalog-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }
  .catalog-head p {
    margin: 0;
    color: #6e6e73;
    font-size: 13px;
  }
  .catalog-head h2 {
    margin: 4px 0 0;
    color: #0b0b0c;
    font-size: 28px;
    line-height: 1.12;
    font-weight: 600;
    letter-spacing: 0;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 20px;
  }
  .pagination {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-top: 34px;
  }
  .pagination a {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0,0,0,.14);
    border-radius: 999px;
    padding: 0 20px;
    color: #1d1d1f;
    font-size: 13px;
  }
  .pagination a:last-child {
    margin-left: auto;
    border-color: #0b0b0c;
    background: #0b0b0c;
    color: #fff;
  }
  @media (max-width: 1380px) {
    .product-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  @media (max-width: 1120px) {
    .product-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .filter-sidebar { width: 280px; flex-basis: 280px; }
  }
  @media (max-width: 900px) {
    .top-filter-bar { top: 0; }
    .search-row,
    .tool-row,
    .chips-row {
      padding-left: 20px;
      padding-right: 20px;
    }
    .products-content-row {
      display: block;
    }
    .filter-sidebar {
      position: static;
      width: auto;
      height: auto;
      border-right: 0;
      border-bottom: 1px solid rgba(0,0,0,.06);
    }
    .filter-sidebar form {
      padding: 20px;
    }
    .products-grid-wrapper {
      padding: 24px 20px 48px;
    }
    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }
    .sort-form span {
      display: none;
    }
  }
  @media (max-width: 560px) {
    .tool-row {
      flex-wrap: wrap;
    }
    .category-pills {
      order: 3;
      flex-basis: 100%;
    }
    .sort-form {
      margin-left: auto;
    }
    .catalog-head {
      align-items: start;
      flex-direction: column;
    }
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

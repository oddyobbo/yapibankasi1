---
import LegacyPanelShell from "../../components/LegacyPanelShell.astro";
import { getBrandPanelFilename, getBrandPanelPageId, getLegacyPanelParts } from "../../lib/legacyPanelEmbed";

const filename = getBrandPanelFilename("talepler");
if (!filename) return Astro.redirect("/giris", 302);
const parts = getLegacyPanelParts(filename);
---
<LegacyPanelShell
  title="Talepler | Marka Paneli | Archilink"
  canonical="/marka-paneli/talepler"
  headFragment={parts.headFragment}
  bodyHtml={parts.bodyHtml}
  bodyClass={parts.bodyClass}
  bodyDataPage={parts.bodyDataPage}
  markaPanelPage={getBrandPanelPageId("talepler")}
/>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getProjects } from "../../lib/catalog.js";

const projects = await getProjects({ limit: 24 });
const locationCount = new Set(projects.map((project) => project.city || project.location).filter(Boolean)).size;
---
<BaseLayout
  title="Projeler | Archilink"
  description="Mimari ürünlerin gerçek proje bağlamında nasıl kullanıldığını keşfet."
  canonical="/projects"
>
  <Header />
  <main>
    <section class="projects-hero page-band">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Referans projeler</p>
          <h1 class="page-title">Ürünleri gerçek mimari bağlamda keşfet.</h1>
          <p class="lead">Projeler; malzemenin nerede, hangi mimari karar içinde ve hangi ürünlerle birlikte kullanıldığını gösterir.</p>
        </div>
        <aside class="hero-panel" aria-label="Proje kataloğu özeti">
          <span>
            <strong>{projects.length}</strong>
            yayınlanmış proje
          </span>
          <span>
            <strong>{locationCount}</strong>
            lokasyon
          </span>
          <a href="/urunler" class="button secondary">Ürün kataloğuna dön</a>
        </aside>
      </div>
    </section>

    <section class="page-band project-list-band">
      <div class="container">
        <div class="section-head">
          <div>
            <p class="eyebrow">Kullanım senaryoları</p>
            <h2 class="section-title">Seçili projeler</h2>
          </div>
          <p>Her proje sayfası ürün bağlantıları, galeri ve proje bilgileriyle SEO uyumlu tek şablondan gelir.</p>
        </div>
        {projects.length ? <div class="grid cards project-grid">{projects.map((project) => <ProjectCard project={project} />)}</div> : <p class="empty">Henüz yayınlanmış proje yok.</p>}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
<style>
  .projects-hero {
    background:
      radial-gradient(circle at 16% 8%, rgba(0,0,0,.06), transparent 26%),
      linear-gradient(180deg, #fff 0%, #f5f5f7 100%);
    border-bottom: 1px solid rgba(0,0,0,.08);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 36px;
    align-items: end;
  }
  .hero-panel {
    display: grid;
    gap: 12px;
    border: 1px solid rgba(0,0,0,.1);
    border-radius: 22px;
    background: rgba(255,255,255,.72);
    padding: 18px;
    backdrop-filter: blur(18px);
  }
  .hero-panel span {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 18px;
    color: #6e6e73;
    font-size: 13px;
  }
  .hero-panel strong {
    color: #111;
    font-size: 28px;
    font-weight: 500;
  }
  .project-list-band { background: #fff; }
  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 28px;
    align-items: end;
    margin-bottom: 22px;
  }
  .section-head p:last-child {
    max-width: 440px;
    margin: 0;
    color: #6e6e73;
    font-size: 14px;
    line-height: 1.55;
  }
  .project-grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
  @media (max-width: 880px) {
    .hero-grid,
    .section-head {
      grid-template-columns: 1fr;
      display: grid;
    }
    .hero-panel { max-width: 420px; }
  }
</style>
